<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Упражнения по Layouts"
        android:textSize="24sp"
        android:textStyle="bold"
        android:gravity="center"
        android:layout_marginBottom="20dp"/>

    <Button
        android:id="@+id/btnLinearLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="3. LinearLayout"
        android:layout_marginBottom="8dp"/>

    <Button
        android:id="@+id/btnTableLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="4. TableLayout"
        android:layout_marginBottom="8dp"/>

    <Button
        android:id="@+id/btnFrameLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="5. FrameLayout"
        android:layout_marginBottom="8dp"/>

    <Button
        android:id="@+id/btnRelativeLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="6. RelativeLayout"
        android:layout_marginBottom="8dp"/>

    <Button
        android:id="@+id/btnConstraintLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="7. ConstraintLayout"
        android:layout_marginBottom="8dp"/>

    <Button
        android:id="@+id/btnGridLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="8. GridLayout"
        android:layout_marginBottom="8dp"/>

    <Button
        android:id="@+id/btnProgrammatic"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="9. Программное создание"
        android:layout_marginBottom="8dp"/>

    <Button
        android:id="@+id/btnCombined"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="10. Совместное использование"
        android:layout_marginBottom="8dp"/>

</LinearLayout>