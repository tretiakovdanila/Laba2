<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- Верхний левый угол -->
    <ImageView
        android:id="@+id/imgTopLeft"
        android:layout_width="60dp"
        android:layout_height="60dp"
        android:src="@drawable/my_image"
        android:contentDescription="Top left image"
        android:layout_margin="16dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- Верхний правый угол -->
    <ImageView
        android:id="@+id/imgTopRight"
        android:layout_width="60dp"
        android:layout_height="60dp"
        android:src="@drawable/my_image2"
        android:contentDescription="Top right image"
        android:layout_margin="16dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- Центральное изображение -->
    <ImageView
        android:id="@+id/imgCenter"
        android:layout_width="80dp"
        android:layout_height="80dp"
        android:src="@drawable/my_image3"
        android:contentDescription="Central image"
        app:layout_constraintBottom_toTopOf="@+id/scrollView"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/imgTopLeft" />

    <!-- Нижний левый угол -->
    <ImageView
        android:id="@+id/imgBottomLeft"
        android:layout_width="60dp"
        android:layout_height="60dp"
        android:src="@drawable/my_image4"
        android:contentDescription="Bottom left image"
        android:layout_margin="16dp"
        app:layout_constraintBottom_toTopOf="@+id/scrollView"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/imgCenter" />

    <!-- Нижний правый угол -->
    <ImageView
        android:id="@+id/imgBottomRight"
        android:layout_width="60dp"
        android:layout_height="60dp"
        android:src="@drawable/my_image5"
        android:contentDescription="Bottom right image"
        android:layout_margin="16dp"
        app:layout_constraintBottom_toTopOf="@+id/scrollView"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@id/imgCenter" />

    <!-- ScrollView с большой картинкой -->
    <ScrollView
        android:id="@+id/scrollView"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="16dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/imgBottomLeft">

        <ImageView
            android:layout_width="match_parent"
            android:layout_height="1000dp"
            android:src="@drawable/my_image"
            android:contentDescription="Large scrollable image"
            android:scaleType="centerCrop" />

    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>